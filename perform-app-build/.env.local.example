# ─────────────────────────────────────────────────────────────────────────────
# BodyTracker environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# In production (Vercel) set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (required) ----------------------------------------------------
# Project URL and PUBLIC anon key. Safe to expose to the browser/iOS client;
# Row Level Security is what protects the data, not the key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase service role (server-only, SECRET) ----------------------------
# Used ONLY by server routes (e.g. /api/account/delete). Bypasses RLS, so it must
# never be prefixed NEXT_PUBLIC_ and never reach the client. Leave blank to
# disable account deletion.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic AI (optional) ------------------------------------------------
# Enables AI Coach, compound-info, and nutrition-review. Without it those
# features return a friendly 503. Server-only — never exposed to the client.
ANTHROPIC_API_KEY=
# Override the default model (claude-sonnet-4-6) if desired.
COACH_MODEL=

# --- Site URL (optional but recommended) ------------------------------------
# Canonical absolute URL of the deployed web app. Used for SEO metadata and as
# the base for auth redirect links. e.g. https://bodytracker.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- iOS / Capacitor (optional) ---------------------------------------------
# The URL the native iOS shell loads. Point this at your deployed web app so
# web and iOS run identical code. Used by capacitor.config.ts.
CAP_SERVER_URL=https://YOUR-DEPLOYMENT.vercel.app
