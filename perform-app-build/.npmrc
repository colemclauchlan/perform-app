# The Apple Health plugin (@perfood/capacitor-healthkit) still declares a
# @capacitor/core ^4 peer range even though it runs fine on Capacitor 6. Without
# this, npm 7+ aborts the whole install on that peer mismatch — which would break
# the Vercel web build. legacy-peer-deps relaxes peer resolution (it does NOT
# change which versions are installed) so installs stay green on Vercel and Mac.
legacy-peer-deps=true
